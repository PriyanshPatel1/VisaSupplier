    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/client": "^6.19.0",
    "@prisma/extension-accelerate": "^1.1.0",
    "@stripe/react-stripe-js": "^6.3.0",
    "@stripe/stripe-js": "^9.4.0",
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.0.0",
    "cloudinary": "^2.9.0",
    "framer-motion": "^12.38.0",
    "jose": "^6.2.2",
    "lucide-react": "^1.14.0",
    "next": "^16.2.4",
    "next-intl": "^4.0.0",
    "nodemailer": "^8.0.5",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "prisma": "^6.19.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.2",
    "stripe": "^22.1.0",
    "zod": "^3.23.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@tailwindcss/postcss": "^4",
    "@types/jest": "^29.0.0",
    "@types/node": "^20",
    "@types/nodemailer": "^6.4.14",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "jest": "^29.0.0",
    "jest-environment-node": "^29.0.0",
    "tailwindcss": "^4",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  },
  "prisma": {
